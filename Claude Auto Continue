// ==UserScript==
// @name         Claude Auto Continue (Time + Message Scheduler)
// @namespace    http://tampermonkey.net/
// @version      3.3
// @match        https://claude.ai/*
// @match        https://*.claude.ai/*
// @grant        none
// ==/UserScript==

(function () {
    'use strict';

    console.log("🔥 Scheduler loaded (time + message mode)");

    // ----------------------------
    // CUSTOM INPUT UI
    // ----------------------------
    const overlay = document.createElement("div");
    overlay.style.position = "fixed";
    overlay.style.top = "0";
    overlay.style.left = "0";
    overlay.style.width = "100%";
    overlay.style.height = "100%";
    overlay.style.background = "rgba(0,0,0,0.6)";
    overlay.style.zIndex = "999999";
    overlay.style.display = "flex";
    overlay.style.alignItems = "center";
    overlay.style.justifyContent = "center";

    overlay.innerHTML = `
        <div style="
            background: #111;
            color: white;
            padding: 20px;
            border-radius: 12px;
            font-family: monospace;
            width: 340px;
        ">
            <h3 style="margin-top:0;">⏰ Scheduler Setup</h3>

            <div style="font-size:12px; opacity:0.8; margin-bottom:8px;">
                Time (24h format)
            </div>

            <div style="font-size:12px; margin-bottom:6px;">
                Examples: 03:10 • 15:45 • 09:05
            </div>

            <input id="timeInput" style="
                width: 100%;
                padding: 8px;
                margin-bottom: 12px;
                border-radius: 6px;
                border: 1px solid #444;
                background: black;
                color: white;
                box-sizing: border-box;
            " placeholder="HH:MM" />

            <div style="font-size:12px; opacity:0.8; margin-bottom:6px;">
                Message to send
            </div>

            <input id="msgInput" style="
                width: 100%;
                padding: 8px;
                margin-bottom: 12px;
                border-radius: 6px;
                border: 1px solid #444;
                background: black;
                color: white;
                box-sizing: border-box;
            " value="Continue" />

            <button id="goBtn" style="
                width: 100%;
                padding: 10px;
                background: green;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
            ">Start</button>
        </div>
    `;

    document.body.appendChild(overlay);

    function getNextRun(hour, minute) {
        const now = new Date();
        const target = new Date();

        target.setHours(hour, minute, 0, 0);

        // If today's time has passed, schedule tomorrow
        if (target <= now) {
            target.setDate(target.getDate() + 1);
        }

        return target;
    }

    function sendMessage(text) {
        const editor = document.querySelector('[contenteditable="true"]');

        if (!editor) {
            console.log("❌ Editor not found");
            return;
        }

        editor.focus();

        document.execCommand('selectAll', false, null);
        document.execCommand('delete', false, null);
        document.execCommand('insertText', false, text);

        editor.dispatchEvent(new InputEvent('input', {
            bubbles: true,
            inputType: 'insertText',
            data: text
        }));

        setTimeout(() => {

            const sendButton = [...document.querySelectorAll('button')]
                .find(b =>
                    (b.ariaLabel || b.getAttribute('aria-label') || '')
                        .toLowerCase()
                        .includes('send')
                );

            if (sendButton) {
                sendButton.click();
                console.log(`📤 Sent: "${text}"`);
            } else {
                console.log("❌ Send button not found");
            }

        }, 800);
    }

    function formatRemaining(ms) {

        let totalSeconds = Math.max(0, Math.floor(ms / 1000));

        const days = Math.floor(totalSeconds / 86400);
        totalSeconds %= 86400;

        const hours = Math.floor(totalSeconds / 3600);
        totalSeconds %= 3600;

        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;

        if (days > 0) {
            return `${days}d ${hours}h ${minutes}m ${seconds}s`;
        }

        if (hours >= 1) {
            return `${hours}h ${minutes}m ${seconds}s`;
        }

        return `${minutes}m ${seconds}s`;
    }

    document.getElementById("goBtn").onclick = () => {

        const timeValue = document.getElementById("timeInput").value.trim();
        const messageValue =
            document.getElementById("msgInput").value.trim() || "Continue";

        const parts = timeValue.split(":");

        if (parts.length !== 2) {
            alert("Invalid time format. Use HH:MM (e.g. 03:10)");
            return;
        }

        const hour = parseInt(parts[0], 10);
        const minute = parseInt(parts[1], 10);

        if (
            isNaN(hour) ||
            isNaN(minute) ||
            hour < 0 ||
            hour > 23 ||
            minute < 0 ||
            minute > 59
        ) {
            alert("Invalid time");
            return;
        }

        overlay.remove();

        const target = getNextRun(hour, minute);
        const delay = target - new Date();

        console.log("⏰ Scheduled for:", target.toString());
        console.log("💬 Message:", messageValue);

        // ----------------------------
        // COUNTDOWN BOX
        // ----------------------------

        const box = document.createElement("div");

        box.style.position = "fixed";
        box.style.bottom = "20px";
        box.style.right = "20px";
        box.style.background = "rgba(0,0,0,0.85)";
        box.style.color = "white";
        box.style.padding = "12px";
        box.style.borderRadius = "10px";
        box.style.fontFamily = "monospace";
        box.style.zIndex = "999999";
        box.style.minWidth = "260px";
        box.style.lineHeight = "1.5";

        document.body.appendChild(box);

        const countdownTimer = setInterval(() => {

            const remaining = target - new Date();

            if (remaining <= 0) {
                return;
            }

            box.innerHTML = `
                ⏳ Scheduler Running<br>
                Target: ${target.toLocaleString()}<br>
                Message: ${messageValue}<br>
                Remaining: ${formatRemaining(remaining)}
            `;

        }, 1000);

        // Initial display immediately
        box.innerHTML = `
            ⏳ Scheduler Running<br>
            Target: ${target.toLocaleString()}<br>
            Message: ${messageValue}<br>
            Remaining: ${formatRemaining(delay)}
        `;

        // ----------------------------
        // EXECUTE ONCE
        // ----------------------------

        setTimeout(() => {

            clearInterval(countdownTimer);

            box.innerHTML = `
                🚀 Triggering...<br>
                Target: ${target.toLocaleString()}<br>
                Message: ${messageValue}
            `;

            console.log("🚀 Trigger Fired");

            sendMessage(messageValue);

            setTimeout(() => {
                box.innerHTML += "<br>✅ Sent";
            }, 1000);

        }, delay);

    };

})();
